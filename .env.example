# ─── Admin Dashboard ─────────────────────────────
# Login credentials for /logmein (also editable defaults; can be overridden in DB via UI later)
ADMIN_USER=admin
ADMIN_PASS=sk-default-key
# Random 32+ char string used to sign admin session cookies
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Turso (libSQL) Database ─────────────────────
# Create at https://turso.tech → Create Database → copy URL + token
TURSO_DATABASE_URL=libsql://your-db-name-yourorg.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOi...

# ─── AI Provider (OpenAI-compatible) ─────────────
# All fields are editable from Admin → Settings → AI Provider.
# These env vars are only used as first-boot defaults.
AI_BASE_URL=https://ai.gateway.lovable.dev/v1
AI_API_KEY=
AI_MODEL=google/gemini-2.5-flash
AI_SYSTEM_PROMPT=You are a senior affiliate-review editor writing SEO-optimized, trustworthy product roundups.

# ─── Site defaults (all editable from admin UI) ──
SITE_URL=
SITE_META_TITLE=YAD Foods — Honest Product Reviews
SITE_META_DESCRIPTION=Independent product reviews and buyer's guides with live pricing.
SITE_GA_ID=
SITE_HEAD_CODE=

# ─── Product data source ─────────────────────────
PRODUCT_API_URL=https://4pobkr5oa4olwuvhx625uiozay0rrcuu.lambda-url.us-east-1.on.aws/
AMAZON_TAG=YOUR-TAG-20

# ─── Amazon PA-API (optional fallback) ───────────
PAAPI_ACCESS_KEY=
PAAPI_SECRET_KEY=
PAAPI_PARTNER_TAG=

# ─── Autopilot / Cron ────────────────────────────
AUTOPILOT_ENABLED=0
AUTOPILOT_BATCH_SIZE=3
AUTOPILOT_INTERVAL_MIN=60
# Secret for POST /api/public/autopilot/run — set here OR from admin UI
CRON_SECRET=

# ─── Cache ───────────────────────────────────────
PRICE_CACHE_TTL_MIN=60
